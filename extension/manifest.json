{
  "manifest_version": 3,
  "name": "LocalHire Agent",
  "version": "2.0",
  "description": "AI-powered job application auto-filler and resume tailoring tool",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*",
    "http://localhost:5000/*",
    "*://*.myworkdayjobs.com/*",
    "*://*.wd1.myworkdayjobs.com/*",
    "*://*.wd3.myworkdayjobs.com/*",
    "*://*.wd5.myworkdayjobs.com/*",
    "*://boards.greenhouse.io/*",
    "*://apply.greenhouse.io/*",
    "*://jobs.lever.co/*",
    "*://*.lever.co/*",
    "*://*.bamboohr.com/*",
    "*://*.icims.com/*",
    "*://careers.smartrecruiters.com/*",
    "*://*.smartrecruiters.com/*",
    "*://www.linkedin.com/*",
    "*://*.taleo.net/*",
    "*://*.successfactors.com/*",
    "*://*.jobvite.com/*",
    "*://*.paylocity.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
